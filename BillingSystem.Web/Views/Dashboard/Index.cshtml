@model BillingSystem.Models.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0">Admin Dashboard</h4>
        <span class="text-muted">Last updated: @DateTime.Now.ToString("dd MMM, hh:mm tt")</span>
    </div>

    @* Financial Stats Summary *@
    <div class="row mb-4">
        <div class="col-md-6 mb-3 mb-md-0">
            <div class="card text-white bg-success p-4 shadow-sm border-0 h-100">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase opacity-75">Total Sales</h6>
                        <h2 class="display-5 fw-bold">₹@Model.TotalSales</h2>
                    </div>
                    <i class="bi bi-currency-rupee fs-1"></i>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card text-white bg-primary p-4 shadow-sm border-0 h-100">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase opacity-75">Total Invoices</h6>
                        <h2 class="display-5 fw-bold">@Model.TotalInvoices</h2>
                    </div>
                    <i class="bi bi-receipt fs-1"></i>
                </div>
            </div>
        </div>
    </div>

    @* Detailed Counts *@
    <div class="row mb-4">
        <div class="col-md-4 mb-3 mb-md-0">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0 bg-info-subtle p-3 rounded">
                            <i class="bi bi-people-fill text-info fs-3"></i>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h6 class="text-muted mb-1">Total Users</h6>
                            <h3 class="mb-0">@Model.TotalUsers</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3 mb-md-0">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0 bg-warning-subtle p-3 rounded">
                            <i class="bi bi-box-seam text-warning fs-3"></i>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h6 class="text-muted mb-1">Total Products</h6>
                            <h3 class="mb-0">@Model.TotalProducts</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0 bg-secondary-subtle p-3 rounded">
                            <i class="bi bi-tags-fill text-secondary fs-3"></i>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h6 class="text-muted mb-1">Categories</h6>
                            <h3 class="mb-0">@Model.TotalCategories</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Recent Bills Table *@
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold">Recent Bills</h5>
            <a asp-controller="Dashboard" asp-action="Reports" class="btn btn-sm btn-outline-primary">View All Reports</a>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Bill ID</th>
                            <th>Date</th>
                            <th>Total Amount</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.RecentBills != null && Model.RecentBills.Any())
                        {
                            foreach (var bill in Model.RecentBills)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-primary">#@bill.Id</td>
                                    <td>@bill.CreatedDate.ToString("dd MMM yyyy")</td>
                                    <td class="fw-bold">₹@bill.TotalAmount</td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-2">
                                            @* View Button *@
                                            <a asp-controller="Bills"
                                               asp-action="Details"
                                               asp-route-id="@bill.Id"
                                               class="btn btn-sm btn-outline-primary"
                                               title="View">
                                                <i class="bi bi-eye"></i> View
                                            </a>

                                            @* Print Button *@
                                            <a asp-controller="Bills"
                                               asp-action="Print"
                                               asp-route-id="@bill.Id"
                                               class="btn btn-sm btn-outline-dark"
                                               title="Print">
                                                <i class="bi bi-printer"></i> Print
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-4 text-muted">No recent bills found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>