@model List<BillingSystem.Models.DTOs.ProductDto>
@{
    ViewData["Title"] = "Generate Bill";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .qty-input:disabled {
        background: #f0f0f0;
        color: #aaa;
        cursor: not-allowed;
    }

    .totals-box {
        margin-left: auto;
        width: 300px;
        margin-top: 16px;
    }

    .totals-row {
        display: flex;
        justify-content: space-between;
        padding: 8px 0;
        border-bottom: 1px solid #dee2e6;
        font-size: 0.93rem;
    }

        .totals-row:last-child {
            border-bottom: none;
        }

        .totals-row.grand .lbl,
        .totals-row.grand .val {
            font-weight: 800;
            font-size: 1.05rem;
            color: #1a3c5e;
        }

        .totals-row .lbl {
            color: #6c757d;
        }

        .totals-row .val {
            font-weight: 600;
        }
</style>

<!-- ═══════════════════════════
     STEP 1 — Product Selection
════════════════════════════ -->
<div id="step1">
    <h4 class="mb-4">Generate Bill</h4>

    <div class="card shadow p-3 mb-3">
        <table class="table table-bordered table-hover table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Select</th>
                    <th>Product Name</th>
                    <th>SubCategory</th>
                    <th>Price</th>
                    <th>Quantity</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.Count; i++)
                {
                    <tr>
                        <td class="text-center">
                            <input type="checkbox"
                                   class="form-check-input prod-check"
                                   data-id="@Model[i].Id"
                                   data-name="@Model[i].Name"
                                   data-subcategory="@Model[i].SubCategoryName"
                                   data-price="@Model[i].Price"
                                   onchange="toggleQty(this)" />
                        </td>
                        <td>@Model[i].Name</td>
                        <td>@Model[i].SubCategoryName</td>
                        <td>₹@Model[i].Price.ToString("N2")</td>
                        <td>
                            <input type="number"
                                   class="form-control qty-input"
                                   value="1" min="1"
                                   style="width:80px"
                                   disabled />
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <button type="button" class="btn btn-success btn-lg" onclick="showBillForm()">
        Generate Bill
    </button>
</div>


<!-- ═══════════════════════════
     STEP 2 — Bill Form
════════════════════════════ -->
<div id="step2" style="display:none">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0">Invoice Preview</h4>
        <button type="button" class="btn btn-outline-secondary btn-sm"
                onclick="document.getElementById('step1').style.display='block';
                         document.getElementById('step2').style.display='none';">
            ← Back to Products
        </button>
    </div>

    <div class="card shadow">

        <!-- Invoice Header -->
        <div class="card-header text-white py-3" style="background:#1a3c5e">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <h5 class="mb-1 fw-bold">Your Company Name</h5>
                    <small style="opacity:.75">Address Line, City, State</small>
                </div>
                <div class="text-end">
                    <h5 class="mb-1 fw-bold" style="color:#e8a020">INVOICE</h5>
                    <small>Bill No: <strong id="displayBillNo">AUTO</strong></small>
                </div>
            </div>
        </div>

        <div class="card-body">

            <!-- Customer Details Form -->
            <form asp-controller="Agent" asp-action="GenerateBill" method="post" id="billForm">
                @Html.AntiForgeryToken()

                <div class="row g-3 mb-4 pb-4 border-bottom">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold small text-muted text-uppercase">Customer Name</label>
                        <input type="text" name="CustomerName" class="form-control"
                               placeholder="Enter customer name" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold small text-muted text-uppercase">Customer Contact</label>
                        <input type="text" name="CustomerContact" class="form-control"
                               placeholder="Mobile / Phone" maxlength="15" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold small text-muted text-uppercase">Bill Date</label>
                        <input type="date" name="BillDate" class="form-control"
                               value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold small text-muted text-uppercase">Remarks</label>
                        <input type="text" name="Remarks" class="form-control"
                               placeholder="Any notes..." />
                    </div>
                </div>

                <!-- Selected Items Table -->
                <p class="fw-bold small text-muted text-uppercase mb-2">Bill Items</p>
                <table class="table table-bordered">
                    <thead class="table-light">
                        <tr>
                            <th>Product Name</th>
                            <th>SubCategory</th>
                            <th>Qty</th>
                            <th>Price (₹)</th>
                            <th class="text-end">Amount (₹)</th>
                        </tr>
                    </thead>
                    <tbody id="billItemsBody"></tbody>
                </table>

                <!-- Hidden inputs posted to controller -->
                <div id="hiddenInputs"></div>

                <!-- Totals -->
                <div class="totals-box">
                    <div class="totals-row">
                        <span class="lbl">Total Amount</span>
                        <span class="val" id="totalAmt">₹0.00</span>
                    </div>
                    <div class="totals-row">
                        <span class="lbl">Sale Tax (18% GST)</span>
                        <span class="val" id="taxAmt">₹0.00</span>
                    </div>
                    <div class="totals-row grand">
                        <span class="lbl">Grand Total</span>
                        <span class="val" id="grandTotal">₹0.00</span>
                    </div>
                    <input type="hidden" name="TotalAmount" id="hidTotal" />
                    <input type="hidden" name="TaxAmount" id="hidTax" />
                    <input type="hidden" name="GrandTotal" id="hidGrand" />
                </div>

                <!-- Action Buttons -->
                <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                    <button type="button" class="btn btn-secondary" onclick="window.print()">
                        🖨 Print
                    </button>
                    <button type="submit" class="btn btn-success btn-lg px-5">
                        Save Bill
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        const TAX = 0.18;

        function toggleQty(cb) {
            const qtyInput = cb.closest('tr').querySelector('.qty-input');
            qtyInput.disabled = !cb.checked;
            if (cb.checked) qtyInput.focus();
        }

            function showBillForm() {
        const checked = document.querySelectorAll('.prod-check:checked');
        if (checked.length === 0) {
            alert('Please select at least one product.');
            return;
        }

        // ── Clear all form fields every time ──
        document.querySelector('[name="CustomerName"]').value    = '';
        document.querySelector('[name="CustomerContact"]').value = '';
        document.querySelector('[name="BillDate"]').value        = new Date().toISOString().split('T')[0];
        document.querySelector('[name="Remarks"]').value         = '';
            const tbody        = document.getElementById('billItemsBody');
            const hiddenInputs = document.getElementById('hiddenInputs');
            tbody.innerHTML        = '';
            hiddenInputs.innerHTML = '';

            let total = 0;
            let idx   = 0;

            checked.forEach(cb => {
                const qty   = parseInt(cb.closest('tr').querySelector('.qty-input').value) || 1;
                const price = parseFloat(cb.dataset.price) || 0;
                const amt   = qty * price;
                total += amt;

                // Display row
                tbody.innerHTML += `
                    <tr>
                        <td>${cb.dataset.name}</td>
                        <td>${cb.dataset.subcategory}</td>
                        <td>${qty}</td>
                        <td>₹${price.toFixed(2)}</td>
                        <td class="text-end fw-semibold">₹${amt.toFixed(2)}</td>
                    </tr>`;

                // Hidden inputs for POST — matches your CreateBillDto Items list
                hiddenInputs.innerHTML += `
                    <input type="hidden" name="Items[${idx}].ProductId" value="${cb.dataset.id}" />
                    <input type="hidden" name="Items[${idx}].Quantity"  value="${qty}" />`;
                idx++;
            });

            const tax   = total * TAX;
            const grand = total + tax;

            document.getElementById('totalAmt').textContent   = '₹' + total.toFixed(2);
            document.getElementById('taxAmt').textContent     = '₹' + tax.toFixed(2);
            document.getElementById('grandTotal').textContent = '₹' + grand.toFixed(2);
            document.getElementById('hidTotal').value = total.toFixed(2);
            document.getElementById('hidTax').value   = tax.toFixed(2);
            document.getElementById('hidGrand').value = grand.toFixed(2);

            document.getElementById('step1').style.display = 'none';
            document.getElementById('step2').style.display = 'block';
        }
    </script>
}