@model List<BillingSystem.Models.DTOs.ProductDto>

@{
    ViewData["Title"] = "Generate Bill";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h4 class="mb-4">Generate Bill</h4>

<form asp-controller="Agent"
      asp-action="GenerateBill"
      method="post">

    <div class="card shadow p-3 mb-3">
        <table class="table table-bordered
                      table-hover table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Select</th>
                    <th>Product Name</th>
                    <th>SubCategory</th>
                    <th>Price</th>
                    <th>Quantity</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0;
                                i < Model.Count; i++)
                {
                    <tr>
                        <td class="text-center">
                            <input type="checkbox"
                                   name="Items[@i].ProductId"
                                   value="@Model[i].Id"
                                   class="form-check-input" />
                        </td>
                        <td>@Model[i].Name</td>
                        <td>@Model[i].SubCategoryName</td>
                        <td>₹@Model[i].Price</td>
                        <td>
                            <input type="number"
                                   name="Items[@i].Quantity"
                                   value="1"
                                   min="1"
                                   class="form-control"
                                   style="width:80px" />
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <button type="submit"
            class="btn btn-success btn-lg">
        Generate Bill
    </button>

</form>