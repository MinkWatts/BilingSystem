@model List<BillingSystem.Models.DTOs.CategoryDto>

@{
    ViewData["Title"] = "Categories";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h4 class="mb-4">Categories Management</h4>

<div class="row">
    <div class="col-md-4">

        <!-- Add Category -->
        <div class="card shadow p-3 mb-4">
            <h5 class="mb-3">Add Category</h5>
            <form asp-controller="Admin"
                  asp-action="AddCategory"
                  method="post">
                <div class="mb-3">
                    <label class="form-label">
                        Category Name
                    </label>
                    <input type="text"
                           name="Name"
                           class="form-control"
                           placeholder="Enter category name"
                           required />
                </div>
                <button type="submit"
                        class="btn btn-primary w-100">
                    Add Category
                </button>
            </form>
        </div>

        <!-- Add SubCategory -->
        <div class="card shadow p-3">
            <h5 class="mb-3">Add SubCategory</h5>
            <form asp-controller="Admin"
                  asp-action="AddSubCategory"
                  method="post">
                <div class="mb-3">
                    <label class="form-label">
                        Select Category
                    </label>
                    <select name="CategoryId"
                            class="form-select"
                            required>
                        <option value="">
                            Select Category
                        </option>
                        @{
                            foreach (var cat in Model)
                            {
                                var catId = cat.Id;
                                var catName = cat.Name;
                                <option value="@catId">
                                    @catName
                                </option>
                            }
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">
                        SubCategory Name
                    </label>
                    <input type="text"
                           name="Name"
                           class="form-control"
                           placeholder="Enter subcategory name"
                           required />
                </div>
                <button type="submit"
                        class="btn btn-success w-100">
                    Add SubCategory
                </button>
            </form>
        </div>

    </div>

    <!-- Categories Table -->
    <div class="col-md-8">
        <div class="card shadow p-3">
            <h5 class="mb-3">All Categories</h5>
            <table id="categoriesTable"
                   class="table table-bordered
                          table-hover table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Category</th>
                        <th>SubCategories</th>
                        <th>Created By</th>
                        <th>Created Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int sr = 1;
                        foreach (var cat in Model)
                        {
                            var catId = cat.Id;
                            var catName = cat.Name;
                            var catBy = cat.CreatedBy;
                            var catDate = cat.CreatedDate
                            .ToString("dd MMM yyyy");

                            <tr>
                                <td>@sr</td>
                                <td>
                                    <strong>@catName</strong>
                                </td>
                                <td>
                                    @foreach (var sub
                                                                in cat.SubCategories)
                                    {
                                        var subId = sub.Id;
                                        var subName = sub.Name;
                                        <span class="badge
                                                        bg-info
                                                        text-dark me-1">
                                            @subName
                                            <a asp-controller="Admin"
                                               asp-action="DeleteSubCategory"
                                               asp-route-id="@subId"
                                               class="text-dark ms-1"
                                               onclick="return confirm('Delete subcategory?')"
                                               style="text-decoration:none">
                                                ×
                                            </a>
                                        </span>
                                    }
                                </td>
                                <td>@catBy</td>
                                <td>@catDate</td>
                                <td>
                                    <a asp-controller="Admin"
                                       asp-action="DeleteCategory"
                                       asp-route-id="@catId"
                                       class="btn btn-sm btn-danger"
                                       onclick="return confirm('Delete this category and all its subcategories?')">
                                        Delete
                                    </a>
                                </td>
                            </tr>
                            sr++;
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#categoriesTable').DataTable({
                pageLength: 10,
                language: {
                    search: "Search Categories:",
                    lengthMenu: "Show _MENU_ records"
                }
            });
        });
    </script>
}