@model List<BillingSystem.Models.DTOs.UserDto>

@{
    ViewData["Title"] = "Users";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4>All Users</h4>
    <a asp-controller="Admin" asp-action="CreateUser" class="btn btn-primary">
        + Add New User
    </a>
</div>

<div class="card shadow p-3">
    <table id="usersTable" class="table table-bordered table-hover table-striped">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Full Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Created By</th>
                <th>Created Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @{
                int sr = 1;
                foreach (var user in Model)
                {
                    <tr>
                        <td>@sr</td>
                        <td>@user.FullName</td>
                        <td>@user.Email</td>
                        <td>
                            @if (user.Role == "Admin")
                            {
                                <span class="badge bg-danger">Admin</span>
                            }
                            else
                            {
                                <span class="badge bg-primary">Agent</span>
                            }
                        </td>
                        <td>@user.CreatedBy</td>
                        <td>@user.CreatedDate.ToString("dd MMM yyyy")</td>
                        <td>
                            <a asp-controller="Admin" asp-action="EditUser" asp-route-id="@user.Id"
                               class="btn btn-sm btn-warning">
                                Edit
                            </a>

                            <a href="javascript:void(0)"
                               onclick="confirmDelete('@user.Id', '@Url.Action("DeleteUser", "Admin")')"
                               class="btn btn-sm btn-danger">
                                Delete
                            </a>
                        </td>
                    </tr>
                    sr++;
                }
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // 1. Delete Confirmation Function
        function confirmDelete(id, url) {
            Swal.fire({
                title: 'Are you sure?',
                text: "You won't be able to revert this!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = url + "/" + id;
                }
            })
        }

        // 2. DataTable Initialization
        $(document).ready(function () {
            $('#usersTable').DataTable({
                pageLength: 10,
                language: {
                    search: "Search Users:",
                    lengthMenu: "Show _MENU_ users",
                    info: "Showing _START_ to _END_ of _TOTAL_ users",
                    paginate: {
                        next: "Next",
                        previous: "Previous"
                    }
                }
            });
        });
    </script>
}